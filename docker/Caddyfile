# Caddy configuration for SSE support (v2+)
# Production-ready Server-Sent Events configuration

sign.signcasa.de {
    # SSE routes - special handling for real-time streams
    handle /api/sign/status/*/stream {
        reverse_proxy backend:9000 {
            # CRITICAL: Disable buffering for SSE
            # Caddy v2+ automatically handles this, but explicit is better
            flush_interval -1

            # Forward client info
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}

            # Long timeout for persistent connections
            transport http {
                read_timeout 1h
                write_timeout 1h
            }
        }

        # SSE response headers
        header Cache-Control "no-cache"
        header Connection "keep-alive"
        header X-Accel-Buffering "no"
    }

    # Regular API routes
    handle /api/* {
        reverse_proxy backend:9000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}

            # Standard timeouts for API
            transport http {
                read_timeout 60s
                write_timeout 60s
            }
        }
    }

    # Frontend
    handle /* {
        reverse_proxy frontend:5175 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}

            # WebSocket support for Vite HMR in dev
            header_up Upgrade {http.request.header.Upgrade}
            header_up Connection {http.request.header.Connection}
        }
    }

    # Automatic HTTPS with Let's Encrypt
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    }

    # Access logging
    log {
        output file /var/log/caddy/access.log
        format json
    }

    # Error logging
    errors {
        log {
            output file /var/log/caddy/error.log
        }
    }
}

# Health check endpoint (internal)
:2019 {
    respond /health 200 {
        body "OK"
    }
}
