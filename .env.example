# Microservice Configuration
SERVICE_NAME=signcasa-signatures
SERVICE_PORT=9000
DEBUG=true
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://signcasa:password@localhost:5432/signcasa

# Email Service (Resend)
RESEND_API_KEY=re_your_api_key_here
FROM_EMAIL=signatures@signcasa.de
FROM_NAME=SignCasa Signatures

# Signature Configuration
SIGNATURE_EXPIRY_DAYS=7
SIGNING_BASE_URL=https://sign.signcasa.de
CALLBACK_TIMEOUT_SECONDS=30

# File Storage
SIGNATURES_STORAGE_PATH=./storage/signatures
MAX_PDF_SIZE_MB=10

# Security
SECRET_KEY=your-secret-key-min-32-chars
ALLOWED_ORIGINS=http://localhost:5174,https://app.signcasa.de

# WhatsApp Business (Premium Feature - Optional)
WHATSAPP_BUSINESS_ENABLED=false
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_ACCESS_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# Monitoring (Optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
